# Copy to .env and fill in. .env is gitignored (G6).

# OpenAI: used ONLY for embeddings (text-embedding-3-small).
# Anthropic has no embeddings API, so retrieval's dense half needs this.
OPENAI_API_KEY=sk-...

# Anthropic: used for the chat LLM (decomposition + synthesis), temperature 0.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: require this key via the x-api-key header for expensive API endpoints.
FAIRWAY_API_KEY=

# Optional: per-IP request cap for guarded endpoints.
FAIRWAY_RATE_LIMIT_PER_MINUTE=60

# Optional future production stores; local dev falls back to SQLite/in-memory state.
DATABASE_URL=
REDIS_URL=
